ODDS_API_KEY=your_odds_api_key
API_FOOTBALL_KEY=your_api_football_key
# Cache TTL for API-Football responses (seconds). 6h default keeps the daily
# scheduler always seeing fresh data; manual `?force=true` ignores cache entirely.
CACHE_TTL_S=21600

BANKROLL=1000
MIN_EDGE=0.03
MAX_STAKE_PCT=0.02

# epl = paper-trade only · world_cup = real recommendations
LEAGUE_MODE=epl

# SMTP (Phase D)
DIGEST_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

EC2_HOST=

DB_PATH=betedge.db

# OFF by default. Set true (and restart) to start the daily jobs:
#   00:00 sync · 08:00 digest · 23:55 P&L snapshot. Times in TIMEZONE.
SCHEDULER_ENABLED=false
TIMEZONE=America/New_York

# Daily API-Football quota cap. Hard stops every sync once exceeded; warning
# email fires the first time today crosses API_QUOTA_WARN_THRESHOLD.
API_QUOTA_DAILY_LIMIT=6000
API_QUOTA_WARN_THRESHOLD=5000

# Basic auth for /admin/* endpoints (manual sync, scheduler control).
# If ADMIN_PASSWORD is unset, every /admin/* call returns 503.
ADMIN_USER=admin
ADMIN_PASSWORD=
